<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>RVA SITREP — Richmond Severe Weather Operating Picture</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0C141D; --panel:#111C28; --panel2:#0E1822; --line:#20303F;
  --text:#DCE6EE; --dim:#8295A6; --amber:#F2A33C; --cyan:#56B8D0;
  --red:#E0524A; --green:#53B17F; --yellow:#E6C84A;
  --display:'Barlow Condensed',sans-serif; --body:'IBM Plex Sans',sans-serif; --mono:'IBM Plex Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:14px;overflow:hidden}
button{font-family:inherit;cursor:pointer}

/* ---------- header ---------- */
header{height:52px;display:flex;align-items:center;gap:14px;padding:0 14px;border-bottom:1px solid var(--line);background:var(--panel2)}
.brand{display:flex;align-items:baseline;gap:8px;white-space:nowrap}
.brand h1{font-family:var(--display);font-weight:700;font-size:24px;letter-spacing:.06em;color:var(--text)}
.brand h1 b{color:var(--amber);font-weight:700}
.brand span{font-family:var(--mono);font-size:10px;color:var(--dim);letter-spacing:.08em;text-transform:uppercase}
.spacer{flex:1}
.clock{font-family:var(--mono);font-size:12px;color:var(--dim)}
.alertbadge{font-family:var(--mono);font-size:11px;padding:4px 9px;border:1px solid var(--line);border-radius:3px;color:var(--dim)}
.alertbadge.hot{border-color:var(--red);color:var(--red)}
.iconbtn{background:none;border:1px solid var(--line);color:var(--dim);border-radius:3px;padding:5px 10px;font-family:var(--mono);font-size:11px}
.iconbtn:hover{color:var(--text);border-color:var(--dim)}

/* ---------- status strip (signature) ---------- */
#strip{height:30px;display:flex;align-items:center;gap:10px;padding:0 14px;border-bottom:1px solid var(--line);font-family:var(--mono);font-size:11.5px;letter-spacing:.04em;background:linear-gradient(90deg,rgba(242,163,60,.10),transparent 60%);overflow:hidden;white-space:nowrap}
#strip .dot{width:7px;height:7px;border-radius:50%;background:var(--green);flex:none}
#strip.warn .dot{background:var(--amber);box-shadow:0 0 8px var(--amber)}
#strip.severe .dot{background:var(--red);box-shadow:0 0 8px var(--red);animation:pulse 1.2s infinite}
#strip .txt{overflow:hidden;text-overflow:ellipsis}
@keyframes pulse{50%{opacity:.35}}
@media (prefers-reduced-motion:reduce){#strip.severe .dot{animation:none}}

/* ---------- layout ---------- */
main{display:flex;height:calc(100% - 82px)}
aside{width:340px;flex:none;background:var(--panel);border-right:1px solid var(--line);display:flex;flex-direction:column;min-height:0}
#map{flex:1;background:#0A1018}
.leaflet-container{background:#0A1018;font-family:var(--body)}

/* tabs */
nav{display:flex;border-bottom:1px solid var(--line)}
nav button{flex:1;background:none;border:none;color:var(--dim);font-family:var(--display);font-weight:600;font-size:14px;letter-spacing:.08em;text-transform:uppercase;padding:10px 0;border-bottom:2px solid transparent}
nav button.on{color:var(--amber);border-bottom-color:var(--amber)}
.pane{display:none;flex:1;overflow-y:auto;min-height:0}
.pane.on{display:block}
.pane::-webkit-scrollbar{width:8px}.pane::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px}

/* layers pane */
.grp{padding:12px 14px;border-bottom:1px solid var(--line)}
.grp h3{font-family:var(--display);font-weight:600;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--dim);margin-bottom:8px}
.lyr{display:flex;align-items:center;gap:10px;padding:6px 0}
.lyr label{flex:1;font-size:13px}
.lyr small{display:block;color:var(--dim);font-size:11px;margin-top:1px}
.sw{position:relative;width:34px;height:18px;flex:none;background:var(--line);border-radius:9px;border:none;transition:background .15s}
.sw::after{content:'';position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:var(--dim);transition:transform .15s,background .15s}
.sw.on{background:rgba(242,163,60,.35)}
.sw.on::after{transform:translateX(16px);background:var(--amber)}
.sw:focus-visible{outline:2px solid var(--cyan);outline-offset:2px}
input[type=range]{width:100%;accent-color:var(--amber)}
.note{padding:12px 14px;color:var(--dim);font-size:12px;line-height:1.5}
.note a{color:var(--cyan);text-decoration:none}
.note a:hover{text-decoration:underline}

/* list cards */
.card{padding:11px 14px;border-bottom:1px solid var(--line)}
.card h4{font-size:13px;font-weight:600;margin-bottom:3px}
.card p{font-size:12px;color:var(--dim);line-height:1.45}
.card .meta{font-family:var(--mono);font-size:10.5px;color:var(--dim);margin-top:5px}
.tag{display:inline-block;font-family:var(--mono);font-size:10px;padding:2px 6px;border-radius:2px;margin-bottom:5px;letter-spacing:.04em}
.empty{padding:28px 18px;text-align:center;color:var(--dim);font-size:12.5px;line-height:1.6}

/* gauge cards */
.gbar{height:6px;background:var(--line);border-radius:3px;margin-top:7px;position:relative;overflow:hidden}
.gbar i{position:absolute;left:0;top:0;bottom:0;background:var(--cyan);border-radius:3px}
.gbar.flood i{background:var(--red)}
.gnum{font-family:var(--mono);font-size:15px;color:var(--cyan)}
.gnum.flood{color:var(--red)}

/* chat */
#chatwrap{display:flex;flex-direction:column;height:100%}
#chatlog{flex:1;overflow-y:auto;padding:10px 14px;min-height:0}
.msg{margin-bottom:10px}
.msg .who{font-family:var(--mono);font-size:10.5px;color:var(--amber)}
.msg .when{font-family:var(--mono);font-size:10px;color:var(--dim);margin-left:6px}
.msg .body{font-size:13px;line-height:1.45;margin-top:2px;word-wrap:break-word}
#chatform{display:flex;gap:6px;padding:10px;border-top:1px solid var(--line)}
#chatform input{flex:1;background:var(--panel2);border:1px solid var(--line);color:var(--text);border-radius:3px;padding:8px 10px;font-family:var(--body);font-size:13px}
#chatform input:focus{outline:none;border-color:var(--amber)}
.send{background:var(--amber);border:none;color:#1A1206;font-family:var(--display);font-weight:700;font-size:14px;letter-spacing:.06em;padding:0 16px;border-radius:3px;text-transform:uppercase}

/* report button + modal */
#reportbtn{position:absolute;bottom:22px;right:14px;z-index:800;background:var(--amber);color:#1A1206;border:none;border-radius:4px;font-family:var(--display);font-weight:700;font-size:16px;letter-spacing:.06em;text-transform:uppercase;padding:11px 18px;box-shadow:0 4px 18px rgba(0,0,0,.5)}
#reportbtn.placing{background:var(--red);color:#fff}
#modal{position:fixed;inset:0;background:rgba(8,12,18,.72);display:none;align-items:center;justify-content:center;z-index:2000;padding:16px}
#modal.on{display:flex}
.sheet{background:var(--panel);border:1px solid var(--line);border-radius:6px;width:100%;max-width:380px;padding:18px}
.sheet h3{font-family:var(--display);font-weight:700;font-size:20px;letter-spacing:.05em;text-transform:uppercase;margin-bottom:12px}
.sheet label{display:block;font-family:var(--mono);font-size:10.5px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin:10px 0 4px}
.sheet select,.sheet textarea,.sheet input{width:100%;background:var(--panel2);border:1px solid var(--line);color:var(--text);border-radius:3px;padding:8px 10px;font-family:var(--body);font-size:13px}
.sheet textarea{resize:vertical;min-height:64px}
.sheet select:focus,.sheet textarea:focus,.sheet input:focus{outline:none;border-color:var(--amber)}
.row{display:flex;gap:8px;margin-top:16px}
.row button{flex:1;padding:10px;border-radius:3px;font-family:var(--display);font-weight:700;font-size:15px;letter-spacing:.05em;text-transform:uppercase;border:1px solid var(--line);background:none;color:var(--dim)}
.row button.primary{background:var(--amber);border-color:var(--amber);color:#1A1206}
.coordline{font-family:var(--mono);font-size:11px;color:var(--cyan)}
.privnote{font-size:11px;color:var(--dim);margin-top:10px;line-height:1.5}

/* mobile */
#paneltoggle{display:none}
@media (max-width:860px){
  .brand span{display:none}
  .clock{display:none}
  main{position:relative}
  aside{position:absolute;left:0;right:0;bottom:0;top:auto;width:100%;height:52%;z-index:900;border-right:none;border-top:1px solid var(--line);transform:translateY(calc(100% - 42px));transition:transform .25s}
  aside.open{transform:translateY(0)}
  #paneltoggle{display:block;width:100%;background:var(--panel2);border:none;border-bottom:1px solid var(--line);color:var(--amber);font-family:var(--display);font-weight:700;font-size:14px;letter-spacing:.1em;text-transform:uppercase;padding:11px}
  #reportbtn{bottom:auto;top:14px}
}
.leaflet-popup-content-wrapper{background:var(--panel);color:var(--text);border:1px solid var(--line);border-radius:5px;font-size:12.5px}
.leaflet-popup-tip{background:var(--panel)}
.leaflet-popup-content{margin:12px 14px;line-height:1.45}
.leaflet-popup-content h4{font-family:var(--display);font-size:16px;letter-spacing:.04em;text-transform:uppercase;margin-bottom:4px}
.leaflet-popup-content .meta{font-family:var(--mono);font-size:10.5px;color:var(--dim)}
.leaflet-container a.leaflet-popup-close-button{color:var(--dim)}
</style>
</head>
<body>

<header>
  <div class="brand"><h1>RVA <b>SITREP</b></h1><span>Richmond severe weather operating picture</span></div>
  <div class="spacer"></div>
  <span class="clock" id="clock">--:--:--</span>
  <span class="alertbadge" id="alertbadge">ALERTS: —</span>
  <button class="iconbtn" id="refreshbtn" title="Refresh all data">↻ REFRESH</button>
</header>

<div id="strip"><span class="dot"></span><span class="txt" id="striptxt">Connecting to National Weather Service…</span></div>

<main>
  <aside id="panel">
    <button id="paneltoggle">▲ &nbsp;Panel</button>
    <nav>
      <button data-pane="layers" class="on">Layers</button>
      <button data-pane="alerts">Alerts</button>
      <button data-pane="rivers">Rivers</button>
      <button data-pane="reports">Reports</button>
      <button data-pane="chat">Chat</button>
    </nav>

    <div class="pane on" id="pane-layers">
      <div class="grp">
        <h3>Weather</h3>
        <div class="lyr"><label>Radar (NEXRAD composite)<small>Iowa State Mesonet · refreshes every 5 min</small></label><button class="sw on" data-layer="radar" aria-label="Toggle radar"></button></div>
        <div style="padding:2px 0 6px"><input type="range" id="radarOpacity" min="20" max="100" value="65" aria-label="Radar opacity"></div>
        <div class="lyr"><label>Warning &amp; watch polygons<small>NWS active alerts, central Virginia</small></label><button class="sw on" data-layer="alerts" aria-label="Toggle alert polygons"></button></div>
      </div>
      <div class="grp">
        <h3>Hydrology</h3>
        <div class="lyr"><label>River gauges<small>USGS real-time stage, James / Appomattox / Pamunkey / Chickahominy</small></label><button class="sw on" data-layer="gauges" aria-label="Toggle river gauges"></button></div>
      </div>
      <div class="grp">
        <h3>Community</h3>
        <div class="lyr"><label>Community reports<small>Crowdsourced — trees down, flooding, blocked roads</small></label><button class="sw on" data-layer="reports" aria-label="Toggle community reports"></button></div>
      </div>
      <div class="grp">
        <h3>External feeds (no public API)</h3>
        <div class="note" style="padding:0">
          These sources don't expose open real-time APIs, so they open in their own windows:<br><br>
          <a href="https://outagemap.dominionenergy.com" target="_blank" rel="noopener">→ Dominion Energy outage map</a><br>
          <a href="https://511.vdot.virginia.gov" target="_blank" rel="noopener">→ VDOT 511 traffic, closures &amp; cameras</a><br>
          <a href="https://www.vaemergency.gov" target="_blank" rel="noopener">→ Virginia Dept. of Emergency Management</a><br>
          <a href="https://www.rva.gov/emergency-management" target="_blank" rel="noopener">→ Richmond Office of Emergency Management</a><br>
          <a href="https://www.weather.gov/akq/" target="_blank" rel="noopener">→ NWS Wakefield forecast office</a>
        </div>
      </div>
      <div class="note">RVA SITREP displays public data and unverified community reports. It is not an official warning source — heed NWS warnings and local emergency management instructions first.</div>
    </div>

    <div class="pane" id="pane-alerts"><div class="empty">Loading active alerts…</div></div>
    <div class="pane" id="pane-rivers"><div class="empty">Loading river gauges…</div></div>
    <div class="pane" id="pane-reports"><div class="empty">Loading community reports…</div></div>

    <div class="pane" id="pane-chat">
      <div id="chatwrap">
        <div class="note" style="border-bottom:1px solid var(--line)">Public channel — everything posted here is visible to everyone using this page. Local observations only.</div>
        <div id="chatlog"><div class="empty">Loading channel…</div></div>
        <div id="chatform">
          <input id="handle" placeholder="Handle" maxlength="20" style="flex:0 0 90px">
          <input id="chatinput" placeholder="Report conditions…" maxlength="280">
          <button class="send" id="chatsend">Send</button>
        </div>
      </div>
    </div>
  </aside>

  <div id="map"></div>
  <button id="reportbtn">＋ Report</button>
</main>

<div id="modal" role="dialog" aria-modal="true">
  <div class="sheet">
    <h3>Submit report</h3>
    <div class="coordline" id="modalcoords"></div>
    <label for="rcat">Category</label>
    <select id="rcat">
      <option value="tree">Tree down</option>
      <option value="line">Power line down</option>
      <option value="flood">Flooding</option>
      <option value="road">Road blocked</option>
      <option value="signal">Traffic signal out</option>
      <option value="outage">Power outage</option>
      <option value="damage">Structure damage</option>
    </select>
    <label for="rdesc">Description</label>
    <textarea id="rdesc" maxlength="240" placeholder="One lane blocked, crews not yet on scene…"></textarea>
    <label for="rname">Handle (optional)</label>
    <input id="rname" maxlength="20" placeholder="Anonymous">
    <p class="privnote">Reports are public, unverified, and visible to everyone using this page. They expire from the map after 48 hours. Don't include personal information. If life or property is in danger, call 911 — do not rely on this form.</p>
    <div class="row">
      <button id="rcancel">Cancel</button>
      <button class="primary" id="rsubmit">Post to map</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
/* ================= RVA SITREP ================= */
const RVA = [37.5407, -77.4360];
const REGION = ['Richmond','Henrico','Chesterfield','Hanover','Goochland','Powhatan','New Kent','Charles City','Petersburg','Hopewell','Colonial Heights','Dinwiddie','Prince George','Amelia','Cumberland','Louisa','Caroline','King William','Fluvanna'];

const GAUGES = [
  {id:'02037500', name:'James River — Westham (Richmond)', lat:37.5626, lon:-77.5497, flood:12, nwps:'https://water.noaa.gov/gauges/rmdv2'},
  {id:'02041650', name:'Appomattox River — Matoaca', lat:37.2243, lon:-77.4747, flood:null, nwps:'https://water.noaa.gov'},
  {id:'01673000', name:'Pamunkey River — Hanover', lat:37.7679, lon:-77.3325, flood:null, nwps:'https://water.noaa.gov'},
  {id:'02042500', name:'Chickahominy River — Providence Forge', lat:37.4313, lon:-77.0533, flood:null, nwps:'https://water.noaa.gov'}
];

const CATS = {
  tree:   {label:'Tree down',          color:'#53B17F', glyph:'T'},
  line:   {label:'Power line down',    color:'#E0524A', glyph:'⚡'},
  flood:  {label:'Flooding',           color:'#56B8D0', glyph:'≈'},
  road:   {label:'Road blocked',       color:'#F2A33C', glyph:'⛔'},
  signal: {label:'Traffic signal out', color:'#E6C84A', glyph:'●'},
  outage: {label:'Power outage',       color:'#9A6FD0', glyph:'⏻'},
  damage: {label:'Structure damage',   color:'#D07A4F', glyph:'▲'}
};

const ALERT_COLORS = {
  'Tornado Warning':'#E0524A','Severe Thunderstorm Warning':'#F2A33C','Flash Flood Warning':'#C0392B',
  'Flood Warning':'#53B17F','Tornado Watch':'#E6C84A','Severe Thunderstorm Watch':'#D8B26A',
  'Flood Watch':'#4E8F6F','Flash Flood Watch':'#4E8F6F','Hurricane Warning':'#C13584','Tropical Storm Warning':'#B05CC4',
  'Winter Storm Warning':'#E66BC8','Ice Storm Warning':'#C77DD8','High Wind Warning':'#D0A33C','Wind Advisory':'#C8B27A'
};
const colorFor = ev => ALERT_COLORS[ev] || '#56B8D0';

/* ---------- map ---------- */
const map = L.map('map', {zoomControl:false}).setView(RVA, 10);
L.control.zoom({position:'topleft'}).addTo(map);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution:'&copy; OpenStreetMap &copy; CARTO', maxZoom:18
}).addTo(map);

const layers = {
  radar: L.tileLayer('', {opacity:.65, maxZoom:18, attribution:'Radar: NOAA / Iowa State Mesonet'}),
  alerts: L.layerGroup(),
  gauges: L.layerGroup(),
  reports: L.layerGroup()
};
Object.values(layers).forEach(l => l.addTo(map));

function refreshRadar(){
  layers.radar.setUrl('https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-900913/{z}/{x}/{y}.png?_=' + Math.floor(Date.now()/300000));
}
refreshRadar();
document.getElementById('radarOpacity').addEventListener('input', e => layers.radar.setOpacity(e.target.value/100));

/* layer toggles */
document.querySelectorAll('.sw').forEach(sw => {
  sw.addEventListener('click', () => {
    const key = sw.dataset.layer, on = sw.classList.toggle('on');
    on ? map.addLayer(layers[key]) : map.removeLayer(layers[key]);
  });
});

/* tabs */
document.querySelectorAll('nav button').forEach(b => b.addEventListener('click', () => {
  document.querySelectorAll('nav button').forEach(x => x.classList.remove('on'));
  document.querySelectorAll('.pane').forEach(x => x.classList.remove('on'));
  b.classList.add('on');
  document.getElementById('pane-' + b.dataset.pane).classList.add('on');
}));

/* mobile panel */
const panel = document.getElementById('panel');
document.getElementById('paneltoggle').addEventListener('click', () => panel.classList.toggle('open'));

/* clock */
setInterval(() => {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-US', {hour12:false}) + ' ET';
}, 1000);

const esc = s => String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const ago = t => { const m = Math.round((Date.now()-t)/60000); return m<1?'just now':m<60?m+' min ago':Math.round(m/60)+' hr ago'; };

/* ---------- NWS alerts ---------- */
async function loadAlerts(){
  const pane = document.getElementById('pane-alerts');
  try{
    const r = await fetch('https://api.weather.gov/alerts/active?area=VA', {headers:{'Accept':'application/geo+json'}});
    const data = await r.json();
    const feats = (data.features||[]).filter(f => {
      const a = f.properties.areaDesc || '';
      return REGION.some(n => a.includes(n));
    });
    layers.alerts.clearLayers();
    feats.forEach(f => {
      if(!f.geometry) return;
      const c = colorFor(f.properties.event);
      L.geoJSON(f.geometry, {style:{color:c, weight:2, fillColor:c, fillOpacity:.14}})
        .bindPopup(`<h4>${esc(f.properties.event)}</h4><div class="meta">Until ${new Date(f.properties.ends||f.properties.expires).toLocaleString()}</div><p style="margin-top:6px">${esc((f.properties.headline||'').slice(0,180))}</p>`)
        .addTo(layers.alerts);
    });
    /* sidebar list */
    pane.innerHTML = feats.length ? feats.map(f => {
      const p = f.properties, c = colorFor(p.event);
      return `<div class="card"><span class="tag" style="background:${c}22;color:${c};border:1px solid ${c}55">${esc(p.event)}</span>
        <h4>${esc(p.areaDesc.split(';').slice(0,4).join('; '))}</h4>
        <p>${esc((p.headline||p.description||'').slice(0,220))}</p>
        <div class="meta">Expires ${new Date(p.ends||p.expires).toLocaleString()}</div></div>`;
    }).join('') : '<div class="empty">No active watches or warnings for the Richmond region.<br><br>Quiet board. Monitoring continues.</div>';
    /* status strip + badge */
    const strip = document.getElementById('strip'), txt = document.getElementById('striptxt'), badge = document.getElementById('alertbadge');
    const warnings = feats.filter(f => /Warning/.test(f.properties.event));
    const severe = feats.filter(f => /Tornado Warning|Severe Thunderstorm Warning|Flash Flood Warning|Hurricane Warning/.test(f.properties.event));
    strip.className = severe.length ? 'severe' : feats.length ? 'warn' : '';
    txt.textContent = feats.length
      ? `${feats.length} ACTIVE ALERT${feats.length>1?'S':''} — ` + [...new Set(feats.map(f=>f.properties.event.toUpperCase()))].slice(0,3).join(' · ')
      : 'NO ACTIVE ALERTS FOR THE RICHMOND REGION — MONITORING';
    badge.textContent = 'ALERTS: ' + feats.length;
    badge.className = 'alertbadge' + (warnings.length ? ' hot' : '');
  }catch(e){
    pane.innerHTML = '<div class="empty">Couldn\'t reach the National Weather Service feed. It will retry automatically — check <a href="https://www.weather.gov/akq/" target="_blank" style="color:var(--cyan)">weather.gov/akq</a> directly in the meantime.</div>';
    document.getElementById('striptxt').textContent = 'NWS FEED UNREACHABLE — RETRYING';
  }
}

/* ---------- USGS gauges ---------- */
async function loadGauges(){
  const pane = document.getElementById('pane-rivers');
  try{
    const ids = GAUGES.map(g=>g.id).join(',');
    const r = await fetch(`https://waterservices.usgs.gov/nwis/iv/?format=json&sites=${ids}&parameterCd=00065&siteStatus=all`);
    const data = await r.json();
    const series = data.value.timeSeries || [];
    layers.gauges.clearLayers();
    const cards = GAUGES.map(g => {
      const ts = series.find(s => s.sourceInfo.siteCode[0].value === g.id);
      const v = ts?.values?.[0]?.value?.slice(-1)[0];
      const stage = v ? parseFloat(v.value) : null;
      const when = v ? new Date(v.dateTime) : null;
      const flooding = g.flood && stage !== null && stage >= g.flood;
      const pct = g.flood && stage !== null ? Math.min(100, (stage/g.flood)*100) : (stage!==null ? 40 : 0);
      const col = flooding ? '#E0524A' : '#56B8D0';
      if(stage !== null){
        L.circleMarker([g.lat, g.lon], {radius:8, color:col, weight:2, fillColor:col, fillOpacity:.35})
          .bindPopup(`<h4>${esc(g.name)}</h4><div class="meta">USGS ${g.id} · ${when.toLocaleTimeString()}</div>
            <p style="margin-top:6px;font-family:var(--mono);font-size:15px;color:${col}">${stage.toFixed(2)} ft</p>
            ${g.flood ? `<div class="meta">NWS flood stage: ${g.flood} ft</div>` : ''}
            <div class="meta"><a href="${g.nwps}" target="_blank" style="color:var(--cyan)">Official gauge page →</a></div>`)
          .addTo(layers.gauges);
      }
      return `<div class="card"><h4>${esc(g.name)}</h4>
        <span class="gnum${flooding?' flood':''}">${stage!==null ? stage.toFixed(2)+' ft' : 'no data'}</span>
        ${g.flood ? `<span class="meta" style="margin-left:8px">flood stage ${g.flood} ft</span>` : `<span class="meta" style="margin-left:8px">flood stage: see official gauge page</span>`}
        <div class="gbar${flooding?' flood':''}"><i style="width:${pct}%"></i></div>
        <div class="meta">${when ? 'USGS · updated '+when.toLocaleTimeString() : 'Gauge offline or not reporting'}</div></div>`;
    }).join('');
    pane.innerHTML = cards + '<div class="note">Stage in feet above gauge datum. Flood stages are set by NWS per gauge — verify at <a href="https://water.noaa.gov" target="_blank">water.noaa.gov</a>.</div>';
  }catch(e){
    pane.innerHTML = '<div class="empty">Couldn\'t reach USGS water services. It will retry automatically.</div>';
  }
}

/* ---------- shared storage: reports ---------- */
const REPORT_TTL = 48*3600*1000;
function reportMarker(rep){
  const cat = CATS[rep.cat] || CATS.damage;
  const icon = L.divIcon({className:'', html:`<div style="width:26px;height:26px;border-radius:50%;background:${cat.color};color:#0C141D;display:flex;align-items:center;justify-content:center;font:700 13px var(--mono);border:2px solid #0C141D;box-shadow:0 0 0 2px ${cat.color}66">${cat.glyph}</div>`, iconSize:[26,26], iconAnchor:[13,13]});
  return L.marker([rep.lat, rep.lon], {icon})
    .bindPopup(`<h4>${cat.label}</h4><div class="meta">${esc(rep.name||'Anonymous')} · ${ago(rep.t)}</div><p style="margin-top:6px">${esc(rep.desc||'')}</p><div class="meta" style="margin-top:6px">Unverified community report</div>`);
}
async function loadReports(){
  const pane = document.getElementById('pane-reports');
  try{
    const listing = await window.storage.list('rpt:', true);
    const keys = (listing?.keys || []).sort().slice(-60);
    const reps = [];
    for(const k of keys){
      try{ const r = await window.storage.get(k, true); if(r) reps.push(JSON.parse(r.value)); }catch(_){}
    }
    const live = reps.filter(r => Date.now() - r.t < REPORT_TTL).sort((a,b)=>b.t-a.t);
    layers.reports.clearLayers();
    live.forEach(r => reportMarker(r).addTo(layers.reports));
    pane.innerHTML = live.length ? live.map(r => {
      const cat = CATS[r.cat] || CATS.damage;
      return `<div class="card"><span class="tag" style="background:${cat.color}22;color:${cat.color};border:1px solid ${cat.color}55">${cat.label}</span>
        <p>${esc(r.desc||'')}</p><div class="meta">${esc(r.name||'Anonymous')} · ${ago(r.t)} · ${r.lat.toFixed(3)}, ${r.lon.toFixed(3)}</div></div>`;
    }).join('') + '<div class="note">Reports are public and unverified. They expire after 48 hours.</div>'
    : '<div class="empty">No community reports in the last 48 hours.<br><br>Tap <b style="color:var(--amber)">＋ Report</b>, then tap the map where it happened.</div>';
  }catch(e){
    pane.innerHTML = '<div class="empty">Report storage unavailable in this view.</div>';
  }
}

/* report placement flow */
let placing = false, placedLatLng = null;
const reportbtn = document.getElementById('reportbtn'), modal = document.getElementById('modal');
reportbtn.addEventListener('click', () => {
  placing = !placing;
  reportbtn.classList.toggle('placing', placing);
  reportbtn.textContent = placing ? '✕ Tap map to place' : '＋ Report';
  map.getContainer().style.cursor = placing ? 'crosshair' : '';
});
map.on('click', e => {
  if(!placing) return;
  placedLatLng = e.latlng;
  document.getElementById('modalcoords').textContent = `LOCATION ${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
  modal.classList.add('on');
});
document.getElementById('rcancel').addEventListener('click', () => modal.classList.remove('on'));
document.getElementById('rsubmit').addEventListener('click', async () => {
  if(!placedLatLng) return;
  const rep = {
    t: Date.now(), lat: placedLatLng.lat, lon: placedLatLng.lng,
    cat: document.getElementById('rcat').value,
    desc: document.getElementById('rdesc').value.trim().slice(0,240),
    name: document.getElementById('rname').value.trim().slice(0,20)
  };
  try{
    await window.storage.set('rpt:' + rep.t + '-' + Math.random().toString(36).slice(2,7), JSON.stringify(rep), true);
  }catch(err){ console.error('report save failed', err); }
  modal.classList.remove('on');
  document.getElementById('rdesc').value = '';
  placing = false; reportbtn.classList.remove('placing'); reportbtn.textContent = '＋ Report';
  map.getContainer().style.cursor = '';
  loadReports();
});

/* ---------- shared storage: chat ---------- */
const chatlog = document.getElementById('chatlog');
async function loadChat(){
  try{
    const listing = await window.storage.list('msg:', true);
    const keys = (listing?.keys || []).sort().slice(-40);
    const msgs = [];
    for(const k of keys){
      try{ const r = await window.storage.get(k, true); if(r) msgs.push(JSON.parse(r.value)); }catch(_){}
    }
    msgs.sort((a,b)=>a.t-b.t);
    const atBottom = chatlog.scrollHeight - chatlog.scrollTop - chatlog.clientHeight < 60;
    chatlog.innerHTML = msgs.length ? msgs.map(m =>
      `<div class="msg"><span class="who">${esc(m.who||'anon')}</span><span class="when">${new Date(m.t).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}</span><div class="body">${esc(m.body)}</div></div>`
    ).join('') : '<div class="empty">Channel is quiet. Post what you\'re seeing — outages, flooding, blocked roads.</div>';
    if(atBottom) chatlog.scrollTop = chatlog.scrollHeight;
  }catch(e){
    chatlog.innerHTML = '<div class="empty">Channel storage unavailable in this view.</div>';
  }
}
async function sendChat(){
  const input = document.getElementById('chatinput'), handle = document.getElementById('handle');
  const body = input.value.trim();
  if(!body) return;
  const who = handle.value.trim().slice(0,20) || 'anon';
  try{ await window.storage.set('handle', who, false); }catch(_){}
  const m = {t: Date.now(), who, body: body.slice(0,280)};
  try{
    await window.storage.set('msg:' + m.t + '-' + Math.random().toString(36).slice(2,7), JSON.stringify(m), true);
    input.value = '';
    loadChat();
  }catch(err){ console.error('chat send failed', err); }
}
document.getElementById('chatsend').addEventListener('click', sendChat);
document.getElementById('chatinput').addEventListener('keydown', e => { if(e.key === 'Enter') sendChat(); });
(async () => { try{ const h = await window.storage.get('handle', false); if(h) { document.getElementById('handle').value = h.value; document.getElementById('rname').value = h.value; } }catch(_){} })();

/* ---------- refresh cycles ---------- */
function refreshAll(){ loadAlerts(); loadGauges(); loadReports(); loadChat(); refreshRadar(); }
document.getElementById('refreshbtn').addEventListener('click', refreshAll);
refreshAll();
setInterval(loadAlerts, 120000);
setInterval(loadGauges, 600000);
setInterval(refreshRadar, 300000);
setInterval(() => { if(!document.hidden){ loadReports(); loadChat(); } }, 45000);
</script>
